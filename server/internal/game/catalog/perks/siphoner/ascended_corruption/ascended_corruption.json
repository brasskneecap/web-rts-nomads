{
  "id": "ascended_corruption",
  "displayName": "Ascended Corruption",
  "description": "Enhances whichever Silver Siphoner perk you own — chains reach further, afflictions cut deeper, shields stretch wider, suffering spreads thicker.",
  "tooltipTemplate": "Enhances your Silver Siphoner perk. Pick a Silver perk to see its specific bonus.",
  "tooltipTemplateByOwnedPerk": {
    "amplify_damage": "Amplify Damage: {amplifyRadiusMultiplier:1}× radius, {amplifyDurationMultiplier:1}× duration, +{amplifyDamageTakenMultiplierBonus%} damage amplification.",
    "chain_siphon": "Chain Siphon: +{chainAdditionalTargetCountBonus:0} target, {chainRangeMultiplier:1}× range, +{chainSecondaryDamageMultiplierBonus%} secondary damage, +{chainSecondaryHealingMultiplierBonus%} secondary healing.",
    "dark_renewal": "Dark Renewal: +{darkMaxSelfShieldBonus:0} self shield cap, +{darkMaxAllyShieldBonus:0} ally shield cap, +{darkAdditionalAllyShieldTargets:0} additional ally targets for overflow shielding.",
    "shared_suffering": "Shared Suffering: {sharedRadiusMultiplier:1}× radius, +{sharedDamageSharePercentBonus%} damage share."
  },
  "icon": "perk-ascended-corruption",
  "config": {
    "amplifyDamageTakenMultiplierBonus": 0.25,
    "amplifyDurationMultiplier": 1.5,
    "amplifyRadiusMultiplier": 1.5,
    "chainAdditionalTargetCountBonus": 1,
    "chainRangeMultiplier": 1.5,
    "chainSecondaryDamageMultiplierBonus": 0.25,
    "chainSecondaryHealingMultiplierBonus": 0.25,
    "darkAdditionalAllyShieldTargets": 2,
    "darkMaxAllyShieldBonus": 40,
    "darkMaxSelfShieldBonus": 40,
    "sharedDamageSharePercentBonus": 0.2,
    "sharedRadiusMultiplier": 1.5
  },
  "perkModifiers": [
    {
      "target": "chain_siphon",
      "ops": [
        { "targetKey": "additionalTargetCount", "op": "add", "sourceKey": "chainAdditionalTargetCountBonus" },
        { "targetKey": "chainRange", "op": "mult", "sourceKey": "chainRangeMultiplier" },
        { "targetKey": "secondaryDamageMultiplier", "op": "add", "sourceKey": "chainSecondaryDamageMultiplierBonus" },
        { "targetKey": "secondaryHealingMultiplier", "op": "add", "sourceKey": "chainSecondaryHealingMultiplierBonus" }
      ]
    },
    {
      "target": "amplify_damage",
      "ops": [
        { "targetKey": "radius", "op": "mult", "sourceKey": "amplifyRadiusMultiplier" },
        { "targetKey": "durationSeconds", "op": "mult", "sourceKey": "amplifyDurationMultiplier" },
        { "targetKey": "damageTakenMultiplier", "op": "add", "sourceKey": "amplifyDamageTakenMultiplierBonus" }
      ]
    },
    {
      "target": "dark_renewal",
      "ops": [
        { "targetKey": "maxSelfShield", "op": "add", "sourceKey": "darkMaxSelfShieldBonus" },
        { "targetKey": "maxAllyShield", "op": "add", "sourceKey": "darkMaxAllyShieldBonus" },
        { "targetKey": "allyTargetCount", "op": "add", "sourceKey": "darkAdditionalAllyShieldTargets" }
      ]
    },
    {
      "target": "shared_suffering",
      "ops": [
        { "targetKey": "radius", "op": "mult", "sourceKey": "sharedRadiusMultiplier" },
        { "targetKey": "damageSharePercent", "op": "add", "sourceKey": "sharedDamageSharePercentBonus" }
      ]
    }
  ],
  "wired": false
}
