{
  "id": "marker_trap",
  "displayName": "Marker Trap",
  "type": "spell",
  "canTargetEnemies": true,
  "castRange": 220,
  "cooldown": 7,
  "tags": [
    "trap"
  ],
  "category": "offensive",
  "targetCount": 1,
  "summonCount": 1,
  "supportsAutoCast": true,
  "autoCastTargetSelector": "closest_enemy_in_range",
  "defaultAutoCast": true,
  "icon": "perk-marker-trap",
  "casterAnimation": "Attacking",
  "schemaVersion": 2,
  "program": {
    "entry": {
      "type": "unit",
      "relations": [
        "enemy"
      ],
      "range": 220
    },
    "triggers": [
      {
        "id": "cast",
        "type": "on_cast_complete",
        "actions": [
          {
            "id": "zone",
            "type": "create_zone",
            "config": {
              "name": "Marker Zone",
              "position": {
                "key": "initial_target"
              },
              "radius": 115,
              "duration": 12,
              "tickInterval": 1,
              "sprite": "marker_trap",
              "triggers": [
                {
                  "id": "entered",
                  "type": "on_tick",
                  "actions": [
                    {
                      "id": "pick_enemy",
                      "type": "select_targets",
                      "target": {
                        "source": "all_in_scene",
                        "relations": [
                          "enemy"
                        ],
                        "radius": 110,
                        "origin": "zone_center"
                      },
                      "outputs": {
                        "targets": "marked_unit"
                      }
                    },
                    {
                      "id": "mark",
                      "type": "apply_status_duration",
                      "input": {
                        "targets": {
                          "key": "marked_unit"
                        }
                      },
                      "config": {
                        "name": "Marked",
                        "duration": 4,
                        "stacking": "refresh",
                        "triggers": [
                          {
                            "id": "marked",
                            "type": "on_action_complete",
                            "actions": [
                              {
                                "id": "vulnerable",
                                "type": "change_stat",
                                "config": {
                                  "stat": "damageTaken",
                                  "op": "add",
                                  "value": 0.2
                                }
                              },
                              {
                                "id": "mark_icon",
                                "type": "apply_mark",
                                "config": {
                                  "icon": "debuff-marked",
                                  "iconKind": "debuff"
                                }
                              },
                              {
                                "id": "expose",
                                "type": "conditional",
                                "config": {
                                  "conditions": [
                                    {
                                      "op": "has_perk",
                                      "right": "exposed_weakness"
                                    }
                                  ],
                                  "then": [
                                    {
                                      "id": "weaken",
                                      "type": "change_stat",
                                      "config": {
                                        "stat": "damageDealt",
                                        "op": "add",
                                        "value": -0.2
                                      }
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  }
}