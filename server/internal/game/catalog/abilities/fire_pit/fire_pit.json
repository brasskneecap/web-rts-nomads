{
  "id": "fire_pit",
  "displayName": "Fire Pit",
  "type": "spell",
  "canTargetEnemies": true,
  "castRange": 220,
  "cooldown": 8,
  "damageType": "fire",
  "tags": [
    "trap"
  ],
  "category": "offensive",
  "targetCount": 1,
  "summonCount": 1,
  "supportsAutoCast": true,
  "autoCastTargetSelector": "closest_enemy_in_range",
  "defaultAutoCast": true,
  "icon": "perk-fire-pit",
  "casterAnimation": "Attacking",
  "schemaVersion": 2,
  "program": {
    "entry": {
      "type": "unit",
      "relations": [
        "enemy"
      ],
      "range": 220
    },
    "triggers": [
      {
        "id": "cast",
        "type": "on_cast_complete",
        "actions": [
          {
            "id": "pit",
            "type": "create_zone",
            "config": {
              "name": "Fire Pit",
              "position": {
                "key": "initial_target"
              },
              "radius": 55,
              "duration": 10,
              "tickInterval": 1,
              "count": 1,
              "spreadDistance": 50,
              "sprite": "fire_pit",
              "triggers": [
                {
                  "id": "tick",
                  "type": "on_tick",
                  "actions": [
                    {
                      "id": "inzone",
                      "type": "select_targets",
                      "target": {
                        "source": "all_in_scene",
                        "origin": "zone_center",
                        "relations": [
                          "enemy"
                        ],
                        "radiusRef": "zone_radius"
                      },
                      "outputs": {
                        "targets": "burning"
                      }
                    },
                    {
                      "id": "deliver",
                      "type": "conditional",
                      "config": {
                        "conditions": [
                          {
                            "op": "has_perk",
                            "right": "lasting_flames"
                          }
                        ],
                        "then": [
                          {
                            "id": "burn",
                            "type": "apply_status_duration",
                            "input": {
                              "targets": {
                                "key": "burning"
                              }
                            },
                            "config": {
                              "name": "Burning",
                              "duration": 8,
                              "stacking": "refresh",
                              "tickInterval": 1,
                              "triggers": [
                                {
                                  "id": "burn_applied",
                                  "type": "on_action_complete",
                                  "actions": [
                                    {
                                      "id": "burn_vfx",
                                      "type": "play_presentation",
                                      "config": {
                                        "asset": "burning",
                                        "bindToStatusDuration": true
                                      }
                                    }
                                  ]
                                },
                                {
                                  "id": "burn_tick",
                                  "type": "on_tick",
                                  "actions": [
                                    {
                                      "id": "burn_dmg",
                                      "type": "deal_damage",
                                      "config": {
                                        "amount": 16,
                                        "type": "fire",
                                        "apRatio": 0.2
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          }
                        ],
                        "else": [
                          {
                            "id": "direct_dmg",
                            "type": "deal_damage",
                            "input": {
                              "targets": {
                                "key": "burning"
                              }
                            },
                            "config": {
                              "amount": 16,
                              "type": "fire",
                              "apRatio": 0.2
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
