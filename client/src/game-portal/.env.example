# Base URL for the Go API server (HTTP/HTTPS).
# The WebSocket URL is derived automatically by swapping the scheme:
#   http  -> ws
#   https -> wss
#
# Leave blank to use the page origin (same-origin via Vite proxy in dev,
# or same-origin when the SPA is served by the Go binary in prod).
#
# Examples:
#   Local dev (Vite proxy):  (empty)
#   Direct to Go:            http://localhost:8080
#   Production:              https://api.yourdomain.com
VITE_API_BASE_URL=
