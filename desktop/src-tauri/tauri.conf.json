{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nomads",
  "version": "0.1.0",
  "identifier": "com.nomads.game",
  "build": {
    "frontendDist": "../../client/src/game-portal/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../../client/src/game-portal",
      "script": "npm run dev"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nomads",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob: http://127.0.0.1:* asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* http://localhost:5173 ws://localhost:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/nomads-server"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}

